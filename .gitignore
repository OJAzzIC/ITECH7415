# Ignore the output binary & build directories
bin/
build/

# Ignore our dataset (not distributed - licensing). The corpus actually
# lives in resources/ at the project root; src/resources/ is the legacy path.
resources/
src/resources/

# Ignore the research paper PDF (copyright)
*.pdf

# Ignore the csv's produced with each successful run
/*.csv

# DS_Store files are relevant only to the Mac they were created on, and shouldn't be stored in the repo.
.DS_Store

# Extra file & folders to ignore...
# Cached files used by Gradle
.gradle/
# Contents are only relevent to the specific machine which created them
.vscode/
